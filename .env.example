# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/ainewsradio

# Redis
REDIS_URL=redis://redis:6379/0

# Default AI Provider
DEFAULT_AI_PROVIDER=openai
DEFAULT_AI_MODEL=gpt-5.2

# Per-step AI configuration
PIPELINE_FACTCHECK_PROVIDER=openai
PIPELINE_FACTCHECK_MODEL=gpt-5.2
PIPELINE_ANALYSIS_PROVIDER=openai
PIPELINE_ANALYSIS_MODEL=gpt-5.2
PIPELINE_SCRIPT_PROVIDER=openai
PIPELINE_SCRIPT_MODEL=gpt-5.2

# API Keys
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
BRAVE_SEARCH_API_KEY=

# Collection
COLLECTION_METHOD=brave
COLLECTION_QUERIES=熊本 ニュース,熊本県 政治,熊本 経済

# Content enrichment
COLLECTION_CRAWL_ENABLED=true
COLLECTION_CRAWL_TIMEOUT=15.0
COLLECTION_CRAWL_MAX_BODY_CHARS=50000
COLLECTION_YOUTUBE_ENABLED=true
COLLECTION_DOCUMENT_ENABLED=true

# AI multi-stage research (opt-in)
COLLECTION_AI_RESEARCH_ENABLED=false
COLLECTION_AI_RESEARCH_MAX_ROUNDS=2
COLLECTION_AI_RESEARCH_PROVIDER=
COLLECTION_AI_RESEARCH_MODEL=

# Media
MEDIA_DIR=/app/media

# Voice/TTS (voicevox, openai, elevenlabs, google)
PIPELINE_VOICE_PROVIDER=voicevox
OPENAI_TTS_MODEL=tts-1
OPENAI_TTS_VOICE=alloy
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
GOOGLE_TTS_VOICE=ja-JP-Neural2-B
GOOGLE_TTS_LANGUAGE_CODE=ja-JP

# VOICEVOX
VOICEVOX_HOST=http://voicevox:50021
VOICEVOX_SPEAKER_ID=3

# Visual (thumbnail/background for video: static or google)
VISUAL_PROVIDER=static
VISUAL_IMAGEN_MODEL=imagen-4.0-fast-generate-001
VISUAL_VEO_MODEL=veo-2.0-generate-001
