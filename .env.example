# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/ainewsradio

# Redis
REDIS_URL=redis://redis:6379/0

# Default AI Provider
DEFAULT_AI_PROVIDER=openai
DEFAULT_AI_MODEL=gpt-5

# Per-step AI configuration
PIPELINE_FACTCHECK_PROVIDER=openai
PIPELINE_FACTCHECK_MODEL=gpt-5
PIPELINE_ANALYSIS_PROVIDER=openai
PIPELINE_ANALYSIS_MODEL=gpt-5
PIPELINE_SCRIPT_PROVIDER=openai
PIPELINE_SCRIPT_MODEL=gpt-5

# API Keys
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
BRAVE_SEARCH_API_KEY=

# Collection
COLLECTION_METHOD=brave
COLLECTION_QUERIES=熊本 ニュース,熊本県 政治,熊本 経済

# Media
MEDIA_DIR=/app/media

# Voice/TTS
PIPELINE_VOICE_PROVIDER=voicevox
OPENAI_TTS_MODEL=tts-1
OPENAI_TTS_VOICE=alloy

# VOICEVOX
VOICEVOX_HOST=http://voicevox:50021
VOICEVOX_SPEAKER_ID=3

# YouTube
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
